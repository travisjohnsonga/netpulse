# Secrets — never committed
.env
.env.*
!.env.example
*.key
*.pem
*.crt
*.p12
*.pfx
secrets/
vault/data/
openbao/data/
# OpenBao auto-generated unseal key + root token — NEVER commit
.init_keys
**/.init_keys

# Python
__pycache__/
*.py[cod]
*.so
venv/
.venv/
*.egg-info/
dist/
build/
.python-version

# Django
*.log
local_settings.py
db.sqlite3
staticfiles/
media/

# Node / Frontend
node_modules/
npm-debug.log*
dist/
build/
.cache/

# Docker
docker-compose.override.yml

# Data Volumes
data/
# Runtime log output only — anchored to repo root so it never swallows the
# `apps/logs/` Django package (that footgun once dropped the whole logs app).
/logs/
influxdb/data/
opensearch/data/
postgres/data/
valkey/data/
nats/data/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Testing
.coverage
htmlcov/
.pytest_cache/
junit/

# Compiled Protobuf
*_pb2.py
*_pb2_grpc.py

# Site-specific MIBs (not committed to the public repo)
mibs/custom/*
!mibs/custom/.gitkeep

# Downloaded MIB collections — fetch via scripts/download_mibs.sh, too large/
# licensing-restricted to commit. READMEs (*.md) stay tracked.
mibs/standard/*.my
mibs/standard/*.mib
mibs/standard/*.txt
mibs/vendor/cisco/*.my
mibs/vendor/cisco/*.mib
mibs/vendor/cisco/*.txt
mibs/vendor/juniper/*.my
mibs/vendor/juniper/*.mib
mibs/vendor/sonicwall/*.my
mibs/vendor/sonicwall/*.mib
mibs/vendor/aruba/*.my
mibs/vendor/aruba/*.mib
mibs/vendor/aos-cx/*.my
mibs/vendor/aos-cx/*.mib
