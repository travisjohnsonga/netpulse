# Secrets — never committed
.env
.env.*
!.env.example
*.key
*.pem
*.crt
*.p12
*.pfx
secrets/
vault/data/
openbao/data/
# OpenBao auto-generated unseal key + root token — NEVER commit
.init_keys
**/.init_keys
# Initial admin credentials written by setup.sh (also lives in ~/) — NEVER commit
netpulse-credentials.txt

# Operator-local notes — lab credentials, site-specific + testing notes.
# NEVER commit (see the LOCAL_NOTES.md template referenced from CLAUDE.md/README).
LOCAL_NOTES.md
local_notes.md
*_local_notes.md

# Python
__pycache__/
*.py[cod]
*.so
venv/
.venv/
*.egg-info/
dist/
build/
.python-version

# Django
*.log
local_settings.py
db.sqlite3
staticfiles/
media/

# Node / Frontend
node_modules/
npm-debug.log*
dist/
build/
.cache/
# tsc -b incremental/build emit (never committed)
*.tsbuildinfo
services/frontend/vite.config.js
services/frontend/vite.config.d.ts

# NetPulse Agent binaries — built by CI / locally, mounted into the api
# container; never committed. (Also covered by the generic dist/ rule above
# and agent/.gitignore; listed explicitly here for clarity.)
agent/dist/
agent/netpulse-agent

# Docker
docker-compose.override.yml

# Data Volumes
data/
# Runtime log output only — anchored to repo root so it never swallows the
# `apps/logs/` Django package (that footgun once dropped the whole logs app).
/logs/
influxdb/data/
opensearch/data/
postgres/data/
valkey/data/
nats/data/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Testing
.coverage
htmlcov/
.pytest_cache/
junit/

# Compiled Protobuf
*_pb2.py
*_pb2_grpc.py

# Site-specific MIBs (not committed to the public repo)
mibs/custom/*
!mibs/custom/.gitkeep

# Downloaded MIB collections — populate via scripts/download_mibs.sh (LibreNMS +
# net-snmp + cisco-mibs; hundreds of files), too large to commit. READMEs stay.
mibs/standard/*.my
mibs/standard/*.mib
mibs/standard/*.txt
mibs/vendor/**/*.my
mibs/vendor/**/*.mib
mibs/vendor/**/*.txt
# Keep the per-vendor READMEs (download instructions) tracked.
!mibs/vendor/*/README.md

# Claude Code session/worktree artifacts
.claude/
