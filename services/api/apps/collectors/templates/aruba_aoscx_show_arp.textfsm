Value PROTOCOL (\S+)
Value IP_ADDRESS (\d+\.\d+\.\d+\.\d+)
Value AGE (\d+|-)
Value MAC_ADDRESS ([0-9a-fA-F]{2}(?::[0-9a-fA-F]{2}){5})
Value INTERFACE (\S+)

Start
  ^Protocol\s+Address\s+Age.*$$ -> Records
  ^${PROTOCOL}\s+${IP_ADDRESS}\s+${AGE}\s+${MAC_ADDRESS}\s+${INTERFACE}\s*$$ -> Record
  ^\s*$$
  ^. -> Next

Records
  ^${PROTOCOL}\s+${IP_ADDRESS}\s+${AGE}\s+${MAC_ADDRESS}\s+${INTERFACE}\s*$$ -> Record
  ^\s*$$
  ^. -> Next
