# Keep the Docker build context to source only. The image runs `npm ci` itself,
# so host node_modules must NOT be copied in (it bloats the context to ~70MB+,
# makes `COPY . .` take minutes, and would overwrite the clean `npm ci` install
# with the host's). dist/ is built inside the image; the rest are dev artifacts.

# Dependencies (reinstalled via `npm ci` in the builder stage)
node_modules

# Build output (produced by `npm run build` inside the image)
dist
build

# VCS + tooling
.git
.gitignore

# Test/coverage artifacts
coverage
.vitest
.nyc_output

# Logs + debug output
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local env / secrets (never bake into an image)
.env
.env.*

# Caches
.cache
.vite
node_modules/.vite

# Editor / OS cruft
.DS_Store
.idea
.vscode

# Docker files themselves don't need to be in the context
Dockerfile
.dockerignore
