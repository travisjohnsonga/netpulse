# NetPulse Environment Configuration
# Copy to .env and fill in values
# NEVER commit .env to version control
#
# WARNING: Change ALL default credentials below before production deployment.

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_DEBUG=false
# Comma-separated hosts Django will serve. setup.sh auto-adds this server's
# detected IP(s) so the dashboard is reachable by IP from a browser. Add any
# DNS name you front NetPulse with.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Set to config.settings.development for local dev without Docker
DJANGO_SETTINGS_MODULE=config.settings.production

# Initial superuser — created only on first startup if the user doesn't exist
# (idempotent; seeded only by the api service). Changing the password here
# after first run has no effect — change it in the UI instead.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@netpulse.local
# Fixed default for the seeded admin. The account is flagged must_change_password,
# so the UI forces a new password on first login — no need to edit this.
DJANGO_SUPERUSER_PASSWORD=NetPulse1!

# PostgreSQL
POSTGRES_DB=netpulse
POSTGRES_USER=netpulse
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# InfluxDB
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_ORG=netpulse
INFLUXDB_BUCKET=metrics
INFLUXDB_ADMIN_TOKEN=change-me
INFLUXDB_ADMIN_PASSWORD=change-me

# OpenSearch
OPENSEARCH_HOST=opensearch
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=change-me

# Valkey
VALKEY_HOST=valkey
VALKEY_PORT=6379
VALKEY_PASSWORD=change-me

# gNMI/SNMP adaptive polling
# While a device streams gNMI, ingest-grpc stamps a Valkey heartbeat and
# ingest-snmp suppresses that device's (redundant) SNMP poll, auto-resuming
# when the stream stalls. Defaults shown; tune only if needed.
ADAPTIVE_POLLING=true          # set false to always SNMP-poll (disable suppression)
GNMI_HEARTBEAT_TTL=180         # heartbeat key TTL in seconds (ingest-grpc)
GNMI_ACTIVE_THRESHOLD=120      # heartbeat younger than this = "gNMI active" (ingest-snmp)
HOSTNAME_CHECK_INTERVAL_S=86400  # scheduler: re-verify device hostnames (SNMP sysName/DNS) cadence

# LLDP "Not in Inventory" page: capabilities hidden by default (comma-separated;
# empty = show all). These are typically unmanaged endpoints not worth adding.
LLDP_EXCLUDE_CAPABILITIES=telephone,station,docsis

# Ping/RTT latency alerting (reachability-monitor). A device must exceed the
# threshold for N consecutive 30s checks before the alert escalates.
PING_LATENCY_WARN_MS=100       # "High Ping Latency" (medium)
PING_LATENCY_WARN_CHECKS=3
PING_LATENCY_CRIT_MS=500       # "Ping Latency Critical" (high)
PING_LATENCY_CRIT_CHECKS=2

# NATS
NATS_URL=nats://nats:4222
NATS_USER=netpulse
NATS_PASSWORD=change-me

# OpenBao (persistent file storage — initialised + auto-unsealed on first run)
OPENBAO_ADDR=http://openbao:8200
# Leave OPENBAO_TOKEN blank in normal operation: the api initialises OpenBao and
# writes the generated root token + unseal key to the openbao-data volume at
# /openbao/data/.init_keys (chmod 640). Services read the token from there when
# this is unset. Set it only to override with an externally-managed token.
OPENBAO_TOKEN=
# The unseal key + root token are auto-managed in /openbao/data/.init_keys.
# They are recorded there, NOT here. Never commit that file. To rotate, see
# docs. (OPENBAO_UNSEAL_KEY / OPENBAO_ROOT_TOKEN are informational only.)
# OPENBAO_UNSEAL_KEY=   # auto-populated in .init_keys
# OPENBAO_ROOT_TOKEN=   # auto-populated in .init_keys — use sparingly

# Ingest Ports
GRPC_PORT=57400
AOS_CX_GNMI_PORT=8443          # AOS-CX gNMI dial-in (ingest-grpc connects to the device)
SYSLOG_UDP_PORT=514
SYSLOG_TCP_PORT=601
NETFLOW_PORT=2055
SFLOW_PORT=6343
SNMP_TRAP_PORT=162
OTLP_GRPC_PORT=4317
OTLP_HTTP_PORT=4318
API_POLLER_WEBHOOK_PORT=8080

# Service Ports (host-side; override to avoid conflicts on shared machines)
API_PORT=8000
WS_PORT=8001
# Web UI ports (host ports mapped to the frontend nginx; docker-compose.yml
# reads FRONTEND_PORT/FRONTEND_HTTPS_PORT — NOT NGINX_HTTP_PORT/NGINX_HTTPS_PORT,
# which are unused and should be removed from any .env to avoid confusion).
# Defaults to the standard 80/443 (required for the bare-host HTTP→HTTPS
# redirect to work). Use 3000/3443 for development if 80/443 are taken.
FRONTEND_PORT=80
FRONTEND_HTTPS_PORT=443

# ingest-api-poller: JSON array of integration configs (leave empty for no integrations)
INTEGRATIONS_JSON=[]

# SSO / Single Sign-On
# Provider client_id/secret are normally configured in the UI (Settings →
# Security → SSO) and the secret is stored in OpenBao. The SOCIAL_AUTH_* vars
# below are optional static fallbacks. Callback URL registered at the provider:
#   https://YOUR_DOMAIN/auth/complete/{backend}/
SSO_ALLOW_LOCAL_LOGIN=true          # always keep local username/password as a fallback
SSO_DEFAULT_ROLE=viewer             # role assigned to new SSO users
FRONTEND_BASE_URL=                  # SSO redirects here with the JWT (e.g. https://netpulse.company.com)
# Google OAuth2 (optional static fallback; UI config overrides these)
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=
# Microsoft Azure AD (Stage 2)
SOCIAL_AUTH_AZUREAD_TENANT_OAUTH2_KEY=
SOCIAL_AUTH_AZUREAD_TENANT_OAUTH2_SECRET=
SOCIAL_AUTH_AZUREAD_TENANT_OAUTH2_TENANT_ID=
# Okta (Stage 2). API URL is derived from okta_domain when configured in the UI.
SOCIAL_AUTH_OKTA_OAUTH2_KEY=
SOCIAL_AUTH_OKTA_OAUTH2_SECRET=
SOCIAL_AUTH_OKTA_OAUTH2_API_URL=
# GitHub (Stage 2)
SOCIAL_AUTH_GITHUB_KEY=
SOCIAL_AUTH_GITHUB_SECRET=

# Alerts
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SLACK_WEBHOOK_URL=
PAGERDUTY_INTEGRATION_KEY=

# Alert-routing email notifications (apps/alerting). When EMAIL_HOST is unset
# the console email backend is used (emails are logged, not sent).
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_FROM=NetPulse Alerts <netpulse@localhost>

# CVE Engine
NVD_API_KEY=
CISCO_PSIRT_CLIENT_ID=
CISCO_PSIRT_CLIENT_SECRET=

# Host IP address — auto-detected by setup.sh and used by the local collector /
# config generator so devices are pointed at the HOST (not a container) IP.
# Override only if auto-detection is wrong.
NETPULSE_HOST_IP=

# Frontend
REACT_APP_API_URL=http://localhost:8000
REACT_APP_WS_URL=ws://localhost:8000
COLLECTOR_IP=

# First-run setup gate.
# Set to true after running scripts/setup.sh.
# Automatically reset to false by scripts/factory-reset.sh.
# While false, the UI shows the /setup welcome page instead of the app.
SETUP_COMPLETE=false

# Version update check (GET /api/version/check/ compares against GitHub).
# Repo is public, so no token is needed. Set GITHUB_TOKEN only for a private
# repo, or VERSION_CHECK_ENABLED=false to disable the check (badge just hides).
GITHUB_REPO=travisjohnsonga/netpulse
GITHUB_BRANCH=main
GITHUB_TOKEN=
VERSION_CHECK_ENABLED=true

# Config push safety
# Allow NetPulse to push configuration to network devices.
# Set to true only after review by your network team.
# Default: false (read-only, monitoring only).
ALLOW_CONFIG_PUSH=false

# Hostname display (display-only — never affects SSH/SNMP/syslog).
# Strip a domain suffix from device hostnames shown in the UI. These are the
# platform defaults; admins can override at runtime in Settings → General.
# If DOMAIN_SUFFIX is empty and stripping is on, everything after the first
# dot is dropped (router1.dnstest.local → router1).
STRIP_DOMAIN_FROM_HOSTNAMES=false
DOMAIN_SUFFIX=

# Scheduled config collection (config-manager). Running configs are collected at
# these two UTC hours daily; each run does change detection and alerts on drift.
# An initial baseline is also collected when a device is approved.
CONFIG_COLLECTION_ENABLED=true
CONFIG_COLLECTION_HOUR_1=7      # morning collection hour (UTC)
CONFIG_COLLECTION_HOUR_2=19     # evening collection hour (UTC)

# Factory reset guard (development only).
# Gates scripts/factory-reset.sh, which wipes all data. Never set true in production.
ALLOW_FACTORY_RESET=false

# Maintenance windows — how far ahead the UI lists upcoming windows.
MAINTENANCE_WINDOW_LOOKAHEAD_DAYS=30

# Discord (optional global fallback; configure per-team in the UI).
# DISCORD_DEFAULT_WEBHOOK=
